rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profiles - only the owner can read/write their own
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Businesses - owner can read/write; staff can read based on role
    match /businesses/{businessId} {
      allow read: if request.auth != null &&
        (resource.data.ownerId == request.auth.uid ||
         exists(/databases/$(database)/documents/businesses/$(businessId)/staff/$(request.auth.uid)));

      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        resource.data.ownerId == request.auth.uid;

      // Customers
      match /customers/{customerId} {
        allow read: if request.auth != null &&
          exists(/databases/$(database)/documents/businesses/$(businessId));
        allow write: if request.auth != null &&
          get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      }

      // Suppliers
      match /suppliers/{supplierId} {
        allow read: if request.auth != null &&
          exists(/databases/$(database)/documents/businesses/$(businessId));
        allow write: if request.auth != null &&
          get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      }

      // Ledger entries
      match /ledger/{entryId} {
        allow read: if request.auth != null &&
          exists(/databases/$(database)/documents/businesses/$(businessId));
        allow write: if request.auth != null &&
          get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      }

      // Invoices
      match /invoices/{invoiceId} {
        allow read: if request.auth != null &&
          exists(/databases/$(database)/documents/businesses/$(businessId));
        allow write: if request.auth != null &&
          get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      }

      // Staff
      match /staff/{staffId} {
        allow read: if request.auth != null &&
          exists(/databases/$(database)/documents/businesses/$(businessId));
        allow write: if request.auth != null &&
          get(/databases/$(database)/documents/businesses/$(businessId)).data.ownerId == request.auth.uid;
      }
    }
  }
}
